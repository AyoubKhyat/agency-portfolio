generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model User {
  id             String   @id @default(cuid())
  fullName       String   @map("full_name")
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           String   @default("sales")
  avatarInitials String   @map("avatar_initials")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ownedProspects      Prospect[]          @relation("ProspectOwner")
  sentProspects       Prospect[]          @relation("ProspectSentBy")
  contactedProspects  Prospect[]          @relation("ProspectContactedBy")
  lastActionProspects Prospect[]          @relation("ProspectLastActionBy")
  activities          ProspectActivity[]
  ownedClients        Client[]            @relation("ClientAccountManager")
  ownedTasks          Task[]              @relation("TaskOwner")
  createdTasks        Task[]              @relation("TaskCreator")
  ownedMeetings       Meeting[]           @relation("MeetingOwner")
  chatChannels        ChannelMember[]

  @@map("users")
}

model Project {
  id        String  @id @default(cuid())
  slug      String  @unique
  category  String
  url       String
  image     String
  tag       String
  visible   Boolean @default(true)
  status    String  @default("DRAFT") // DRAFT | IN_PROGRESS | REVIEW | COMPLETED | PUBLISHED
  sortOrder Int     @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations ProjectTranslation[]

  @@map("projects")
}

model ProjectTranslation {
  id        String @id @default(cuid())
  projectId String @map("project_id")
  locale    String

  title String
  desc  String
  tags  String

  tagline      String?
  metaDesc     String? @map("meta_desc")
  client       String?
  industry     String?
  challenge    String?
  solution     String?
  step1Title   String? @map("step1_title")
  step1Desc    String? @map("step1_desc")
  step2Title   String? @map("step2_title")
  step2Desc    String? @map("step2_desc")
  step3Title   String? @map("step3_title")
  step3Desc    String? @map("step3_desc")
  features     String?
  tech         String?
  result1Value String? @map("result1_value")
  result1Label String? @map("result1_label")
  result2Value String? @map("result2_value")
  result2Label String? @map("result2_label")
  result3Value String? @map("result3_value")
  result3Label String? @map("result3_label")
  results      String?
  testimonial  String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@map("project_translations")
}

model Lead {
  id             String  @id @default(cuid())
  fullName       String  @map("full_name")
  email          String
  phone          String?
  subject        String
  message        String
  status         String  @default("NEW")
  assignedToId   String? @map("assigned_to_id")
  assignedToName String? @map("assigned_to_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  notes LeadNote[]

  @@map("leads")
}

model LeadNote {
  id       String   @id @default(cuid())
  leadId   String   @map("lead_id")
  content  String
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_notes")
}

model Prospect {
  id           String    @id @default(cuid())
  name         String
  phone        String
  whatsappLink String    @map("whatsapp_link")
  sector       String
  neighborhood String    @default("")
  instagram    String    @default("")
  hasWebsite   Boolean   @default(false) @map("has_website")
  priority     Int       @default(2)
  status       String    @default("A_ENVOYER")
  sentAt       DateTime? @map("sent_at")
  followUpDate    DateTime? @map("follow_up_date")
  proposalAmount  Float?    @map("proposal_amount")
  proposalDate    DateTime? @map("proposal_date")
  proposalStatus  String?   @map("proposal_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ownerUserId         String?   @map("owner_user_id")
  sentByUserId        String?   @map("sent_by_user_id")
  sentByName          String?   @map("sent_by_name")
  contactedByUserId   String?   @map("contacted_by_user_id")
  contactedByName     String?   @map("contacted_by_name")
  contactedAt         DateTime? @map("contacted_at")
  lastActionByUserId  String?   @map("last_action_by_user_id")
  lastActionByName    String?   @map("last_action_by_name")
  lastActionAt        DateTime? @map("last_action_at")

  owner           User?  @relation("ProspectOwner", fields: [ownerUserId], references: [id])
  sentByUser      User?  @relation("ProspectSentBy", fields: [sentByUserId], references: [id])
  contactedByUser User?  @relation("ProspectContactedBy", fields: [contactedByUserId], references: [id])
  lastActionByUser User? @relation("ProspectLastActionBy", fields: [lastActionByUserId], references: [id])

  notes      ProspectNote[]
  activities ProspectActivity[]
  proposals  Proposal[]
  spawnedClients Client[] @relation("ClientFromProspect")
  meetings   Meeting[]
  contracts  Contract[]

  @@map("prospects")
}

model ProspectNote {
  id         String   @id @default(cuid())
  prospectId String   @map("prospect_id")
  content    String
  authorId   String?  @map("author_id")
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@map("prospect_notes")
}

model ProspectActivity {
  id             String   @id @default(cuid())
  prospectId     String   @map("prospect_id")
  userId         String   @map("user_id")
  userName       String   @map("user_name")
  actionType     String   @map("action_type")
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")
  details        String?
  createdAt      DateTime @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("prospect_activities")
}

model Proposal {
  id            String   @id @default(cuid())
  prospectId    String   @map("prospect_id")
  clientId      String?  @map("client_id")
  contactPerson String   @default("") @map("contact_person")
  services      String
  amount        Float
  currency      String   @default("MAD")
  timeline      String   @default("")
  paymentTerms  String   @default("") @map("payment_terms")
  notes         String   @default("")
  packageName   String?  @map("package_name")
  status        String   @default("DRAFT")
  sentAt        DateTime? @map("sent_at")
  createdById   String   @map("created_by_id")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id])
  contracts Contract[]

  @@map("proposals")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model ClientProject {
  id           String    @id @default(cuid())
  name         String
  clientName   String    @map("client_name")
  clientId     String?   @map("client_id")
  description  String    @default("")
  services     String    @default("")
  status       String    @default("NEW")
  priority     String    @default("MEDIUM")
  budget       Float     @default(0)
  amountPaid   Float     @default(0) @map("amount_paid")
  currency     String    @default("MAD")
  startDate    DateTime? @map("start_date")
  dueDate      DateTime? @map("due_date")
  completedAt  DateTime? @map("completed_at")
  progress     Int       @default(0)
  ownerUserId  String?   @map("owner_user_id")
  ownerName    String?   @map("owner_name")
  prospectId   String?   @map("prospect_id")
  proposalId   String?   @map("proposal_id")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  client       Client?   @relation(fields: [clientId], references: [id])

  @@map("client_projects")
}

model Client {
  id                String   @id @default(cuid())
  companyName       String   @map("company_name")
  contactPerson     String   @default("") @map("contact_person")
  phone             String   @default("")
  whatsapp          String   @default("")
  email             String   @default("")
  website           String   @default("")
  industry          String   @default("")
  contractValue     Float    @default(0) @map("contract_value")
  acquisitionSource String   @default("") @map("acquisition_source")
  status            String   @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  accountManagerId  String?  @map("account_manager_id")
  prospectId        String?  @map("prospect_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  accountManager User?     @relation("ClientAccountManager", fields: [accountManagerId], references: [id])
  prospect       Prospect? @relation("ClientFromProspect", fields: [prospectId], references: [id])

  projects   ClientProject[]
  proposals  Proposal[]
  notes      ClientNote[]
  activities ClientActivity[]
  meetings   Meeting[]
  contracts  Contract[]

  @@map("clients")
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  clientId    String?  @map("client_id")
  prospectId  String?  @map("prospect_id")
  ownerId     String?  @map("owner_id")
  ownerName   String?  @map("owner_name")
  type        String   @default("CALL")      // CALL | GOOGLE_MEET | ZOOM | WHATSAPP | IN_PERSON
  status      String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED | NO_SHOW
  startAt     DateTime @map("start_at")
  endAt       DateTime? @map("end_at")
  notes       String   @default("")
  outcome     String   @default("")
  nextAction  String   @default("") @map("next_action")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client   Client?   @relation(fields: [clientId], references: [id])
  prospect Prospect? @relation(fields: [prospectId], references: [id])
  owner    User?     @relation("MeetingOwner", fields: [ownerId], references: [id])

  @@index([clientId])
  @@index([prospectId])
  @@index([ownerId, status])
  @@index([startAt, status])
  @@map("meetings")
}

model Contract {
  id            String    @id @default(cuid())
  clientId      String?   @map("client_id")
  proposalId    String?   @map("proposal_id")
  prospectId    String?   @map("prospect_id")
  title         String
  amount        Float     @default(0)
  currency      String    @default("MAD")
  status        String    @default("DRAFT") // DRAFT | PENDING_SIGNATURE | SIGNED | ACTIVE | COMPLETED | CANCELLED
  paymentTerms  String    @default("") @map("payment_terms")
  notes         String    @default("")
  signedDate    DateTime? @map("signed_date")
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  createdById   String?   @map("created_by_id")
  createdByName String?   @map("created_by_name")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  client   Client?   @relation(fields: [clientId], references: [id])
  proposal Proposal? @relation(fields: [proposalId], references: [id])
  prospect Prospect? @relation(fields: [prospectId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  isDm        Boolean  @default(false) @map("is_dm")
  createdAt   DateTime @default(now()) @map("created_at")

  members  ChannelMember[]
  messages ChatMessage[]

  @@map("chat_channels")
}

model ChannelMember {
  id         String    @id @default(cuid())
  channelId  String    @map("channel_id")
  userId     String    @map("user_id")
  lastReadAt DateTime? @map("last_read_at")
  joinedAt   DateTime  @default(now()) @map("joined_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([userId])
  @@map("chat_channel_members")
}

model ChatMessage {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  authorId    String   @map("author_id")
  authorName  String   @map("author_name")
  content     String
  attachType  String?  @map("attach_type")  // PROSPECT | CLIENT | PROJECT | TASK | MEETING
  attachId    String?  @map("attach_id")
  attachLabel String?  @map("attach_label")
  attachHref  String?  @map("attach_href")
  fileUrl     String?  @map("file_url")
  fileName    String?  @map("file_name")
  fileType    String?  @map("file_type")
  createdAt   DateTime @default(now()) @map("created_at")

  channel   Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reactions ChatReaction[]

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("chat_reactions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  action    String   // LOGIN, LOGOUT, CREATE_PROJECT, UPDATE_PROJECT, DELETE_PROJECT, UPDATE_LEAD, RESET_PASSWORD, etc.
  entity    String?  // "project", "lead", "prospect", "user", etc.
  entityId  String?  @map("entity_id")
  details   String?  // JSON string with extra info
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ClientNote {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  content    String
  authorId   String?  @map("author_id")
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_notes")
}

model ClientActivity {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  actionType String   @map("action_type")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_activities")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status      String    @default("TODO")   // TODO | IN_PROGRESS | BLOCKED | DONE
  dueDate     DateTime? @map("due_date")
  parentType  String?   @map("parent_type") // PROSPECT | CLIENT | PROJECT | PROPOSAL
  parentId    String?   @map("parent_id")
  parentLabel String?   @map("parent_label") // denormalized display name
  ownerId     String?   @map("owner_id")
  ownerName   String?   @map("owner_name")
  createdById String?   @map("created_by_id")
  createdByName String? @map("created_by_name")
  completedAt DateTime? @map("completed_at")
  completedById String? @map("completed_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner   User? @relation("TaskOwner",   fields: [ownerId],     references: [id])
  creator User? @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([ownerId, status])
  @@index([parentType, parentId])
  @@index([dueDate, status])
  @@map("tasks")
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique @map("invoice_number")
  proposalId    String?   @map("proposal_id")
  clientName    String    @map("client_name")
  clientEmail   String?   @map("client_email")
  clientPhone   String?   @map("client_phone")
  clientAddress String?   @map("client_address")
  items         String    // JSON array: [{description, quantity, unitPrice, total}]
  subtotal      Float     @default(0)
  taxRate       Float     @default(20) @map("tax_rate")
  taxAmount     Float     @default(0) @map("tax_amount")
  total         Float     @default(0)
  currency      String    @default("MAD")
  status        String    @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  dueDate       DateTime? @map("due_date")
  paidAt        DateTime? @map("paid_at")
  notes         String?
  createdById   String    @map("created_by_id")
  createdByName String    @map("created_by_name")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("invoices")
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  locale    String   @default("fr")
  title     String
  excerpt   String
  content   String   // markdown content
  category  String
  readTime  Int      @default(5) @map("read_time")
  author    String   @default("Ibda3 Digital")
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, locale])
  @@index([locale, published])
  @@map("blog_posts")
}

model Webhook {
  id        String   @id @default(cuid())
  name      String
  url       String
  events    String   // comma-separated: "lead.new,prospect.created,proposal.sent"
  isActive  Boolean  @default(true) @map("is_active")
  secret    String?  // optional HMAC-SHA256 signing secret
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("webhooks")
}
